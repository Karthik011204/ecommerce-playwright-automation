{
  "info": {
    "name": "Ecommerce API Testing",
    "_postman_id": "abcd1234-abcd-1234-abcd-1234567890",
    "description": "CRUD API Testing Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET Users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-api-key",
            "value": "{{api_key}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/users?page=2",
          "host": ["{{base_url}}"],
          "path": ["users"],
          "query": [
            {
              "key": "page",
              "value": "2"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
